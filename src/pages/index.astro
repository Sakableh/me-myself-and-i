---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import ThemeChangeCard from "../components/ThemeChangeCard.astro";
import TimeZone from "../components/TimeZoneCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import MyStack from "../components/MyStack.astro";
import { SITE } from "../site-config";
---

<script>
  import { stagger, animate } from "motion";
  import { loaderAnimation } from "../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.2),
      },
    ],
  ];

  animate(sequence);
</script>

<Layout
  description={`${SITE.author.fullName} — homelab journal documenting network setups, self-hosting experiments, and infrastructure tinkering from ${SITE.location.countryName}.`}
  title={`${SITE.author.fullName} - ${SITE.author.jobTitle}`}
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <IntroCard />
    <AboutMe />
    <ContactsCard />
    <TimeZone />
    <MyStack />
    <Now />
    <Card
      href="/blog"
      colSpan="md:col-span-2"
      rowSpan="md:row-span-2"
      title="Blog"
    />
    <ThemeChangeCard />

    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <p class="text-xs">
        © 2026 · Built with <a
          class="text-red-500"
          href="https://astro.build/"
          target="_blank">Astro</a
        > on Cloudflare Pages.
      </p>
    </Card>
  </main>
</Layout>
