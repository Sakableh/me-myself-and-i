---
import { getEntry, render } from "astro:content";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/helpers";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { SITE } from "../../site-config";

export const prerender = true;

export async function getStaticPaths() {
  return (await getCollection("blog")).map(({ id }) => ({
    params: { id: id as string },
  }));
}

const { id } = Astro.params;

if (!id) {
  throw new Error("id is missing");
}

const entry = await getEntry("blog", id);

if (!entry) {
  return Astro.redirect("/404");
}

const { Content, remarkPluginFrontmatter } = await render(entry);
---

<BlogLayout
  description={entry.data.description!}
  title={`${entry.data.title} — ${SITE.author.shortName}`}
  currentPage="blog"
>
  <div class="max-w-3xl mx-auto">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center text-neutral-400 hover:text-neutral-200 transition-colors text-sm mb-8"
    >
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      All posts
    </a>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 text-darkslate-300 text-sm mb-3">
        <time datetime={entry.data.pubDate!.toISOString()}>
          {formatDate(entry.data.pubDate!)}
        </time>
        {entry.data.category && (
          <>
            <span>·</span>
            <span class="text-primary-400">{entry.data.category}</span>
          </>
        )}
        <span>·</span>
        <span>{remarkPluginFrontmatter.minutesRead}</span>
      </div>
      <h1 class="text-4xl font-bold text-neutral-100 font-[var(--font-cabinet-grotesk)]">
        {entry.data.title}
      </h1>
      {entry.data.description && (
        <p class="text-neutral-400 mt-3 text-lg">{entry.data.description}</p>
      )}
    </div>

    <!-- Article content -->
    <article class="prose prose-invert prose-slate max-w-none">
      <Content />
    </article>

    <!-- Footer nav -->
    <div class="mt-16 pt-8 border-t border-darkslate-400">
      <a
        href="/blog"
        class="inline-flex items-center text-neutral-400 hover:text-neutral-200 transition-colors text-sm"
      >
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to all posts
      </a>
    </div>
  </div>
</BlogLayout>

<style is:global>
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    margin-top: 20px;
    margin-bottom: 10px;
    font-weight: bold;
  }

  h1 {
    font-size: 32px;
  }

  h2 {
    font-size: 28px;
  }

  h3 {
    font-size: 24px;
  }

  h4 {
    font-size: 20px;
  }

  h5 {
    font-size: 18px;
  }

  h6 {
    font-size: 16px;
  }

  p {
    margin: 0 0 10px 0;
  }

  a {
    color: var(--primary-500);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  ul,
  ol {
    margin-left: 20px;
    margin-bottom: 10px;
    color: var(--darkslate-100);
  }

  blockquote {
    margin: 20px 0;
    padding-left: 15px;
    border-left: 3px solid var(--darkslate-400);
    color: var(--darkslate-300);
  }

  pre,
  code {
    font-family: "Courier New", monospace;
    background-color: var(--darkslate-600);
    border-radius: 5px;
  }

  pre {
    padding: 10px;
    overflow-x: auto;
  }

  code {
    padding: 2px 4px;
    font-size: 90%;
  }

  img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  table {
    border-collapse: collapse;
    width: 100%;
  }

  th,
  td {
    text-align: left;
    padding: 8px;
    border-bottom: 1px solid var(--darkslate-400);
  }

  th {
    color: var(--neutral-50);
  }

  td {
    color: var(--darkslate-100);
  }
</style>
