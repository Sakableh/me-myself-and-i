---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import PostCard from "../../components/Blog/PostCard.astro";
import { SITE } from "../../site-config";

const posts = (await getCollection("blog"))?.sort(
  (blogEntryA, blogEntryB) =>
    (blogEntryB.data.pubDate || new Date()).getTime() -
    (blogEntryA.data.pubDate || new Date()).getTime()
);
---

<BlogLayout
  description="Build logs, setup notes, and homelab experiments"
  title={`Blog — ${SITE.author.shortName}`}
  currentPage="blog"
>
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-neutral-100 font-[var(--font-cabinet-grotesk)]">
        Blog
      </h1>
      <p class="text-neutral-400 mt-2 text-lg">
        Build logs, setup notes, cost breakdowns, and experiments from my
        homelab.
      </p>
    </div>

    <!-- Post list -->
    <div>
      {
        posts?.length === 0 && (
          <p class="text-neutral-400 text-lg py-12 text-center">
            No posts yet. Check back soon.
          </p>
        )
      }
      {
        posts?.map((post) => (
          <PostCard
            title={post.data.title || "No title"}
            description={post.data.description}
            date={post.data.pubDate || new Date()}
            id={post.id}
            category={post.data.category}
          />
        ))
      }
    </div>
  </div>
</BlogLayout>
